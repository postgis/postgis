    <para>
    <informalfigure>
      <mediaobject>
        <imageobject>
          <imagedata fileref="images/st_simplifypolygonhull01.png"/>
        </imageobject>
        <caption><para>Outer hull simplification of a MultiPolygon, with segmentization</para></caption>
