<section xmlns="http://docbook.org/ns/docbook" version="5.0" xml:id="reference_sfcgal_legacy">
    <title>Deprecated SFCGAL Function Aliases</title>
    <para>
        These <code>ST_</code> names remain available for compatibility and emit deprecation notices.
        Their entries contain only the legacy signature and migration link. Use the corresponding
        <code>CG_</code> pages for behavior, examples, and geometry support details.
    </para>

    <refentry xml:id="ST_3DIntersection" role="deprecated-alias">
        <refnamediv>
            <refname>ST_3DIntersection</refname>
            <refpurpose>Deprecated alias for <function>CG_3DIntersection</function>.</refpurpose>
        </refnamediv>
        <refsynopsisdiv>
            <funcsynopsis>
                <funcprototype>
                    <funcdef>geometry <function>ST_3DIntersection</function></funcdef>
                    <paramdef><type>geometry</type> <parameter>geom1</parameter></paramdef>
                    <paramdef><type>geometry</type> <parameter>geom2</parameter></paramdef>
                </funcprototype>
            </funcsynopsis>
        </refsynopsisdiv>
        <refsection>
            <title>Description</title>
            <warning>
                <para><function>ST_3DIntersection</function> is deprecated as of 3.5.0. Use <xref linkend="CG_3DIntersection" /> instead.</para>
            </warning>
            <para role="availability" conformance="2.1.0">Availability: 2.1.0</para>
            <para>&sfcgal_required;</para>
        </refsection>
    </refentry>

