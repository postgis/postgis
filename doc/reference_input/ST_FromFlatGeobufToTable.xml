<refentry xml:id="ST_FromFlatGeobufToTable" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
	  <refnamediv>
		<refname>ST_FromFlatGeobufToTable</refname>

		<refpurpose>Creates a table based on the structure of FlatGeobuf data.</refpurpose>
	  </refnamediv>
	  <refsynopsisdiv>
		<funcsynopsis>
		<funcprototype>
				<funcdef>void <function>ST_FromFlatGeobufToTable</function></funcdef>
				<paramdef><type>text </type> <parameter>schemaname</parameter></paramdef>
				<paramdef><type>text </type> <parameter>tablename</parameter></paramdef>
				<paramdef><type>bytea </type> <parameter>FlatGeobuf input data</parameter></paramdef>
			</funcprototype>
		</funcsynopsis>
	  </refsynopsisdiv>

	  <refsection>
		<title>Description</title>

		<para>
			Creates a table based on the structure of FlatGeobuf data. (<link xlink:href="http://flatgeobuf.org">http://flatgeobuf.org</link>).
		</para>

		<para><varname>schema</varname> Schema name.</para>
		<para><varname>table</varname> Table name.</para>
		<para><varname>data</varname> Input FlatGeobuf data.</para>

		<para role="availability" conformance="3.2.0">Availability: 3.2.0</para>
	  </refsection>
	</refentry>
