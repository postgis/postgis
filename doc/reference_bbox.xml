        <refentry xml:id="ST_XMax">
      <refnamediv>
        <refname>ST_XMax</refname>

        <refpurpose>Returns the X maxima of a 2D or 3D bounding box or a geometry.</refpurpose>
      </refnamediv>

      <refsynopsisdiv>
