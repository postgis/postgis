<refentry xml:id="RT_ST_Intersects" xmlns="http://docbook.org/ns/docbook">
        <refnamediv>
            <refname>ST_Intersects</refname>
            <refpurpose>Return true if raster rastA spatially intersects raster rastB.</refpurpose>
        </refnamediv>

        <refsynopsisdiv>
            <funcsynopsis>
                <funcprototype>
                    <funcdef>boolean <function>ST_Intersects</function></funcdef>
                    <paramdef>
                        <type>raster </type>
                        <parameter>rastA</parameter>
                    </paramdef>
                    <paramdef>
                        <type>integer </type>
                        <parameter>nbandA</parameter>
                    </paramdef>
                    <paramdef>
                        <type>raster </type>
                        <parameter>rastB</parameter>
                    </paramdef>
                    <paramdef>
                        <type>integer </type>
                        <parameter>nbandB</parameter>
                    </paramdef>
                </funcprototype>

                <funcprototype>
                    <funcdef>boolean <function>ST_Intersects</function></funcdef>
