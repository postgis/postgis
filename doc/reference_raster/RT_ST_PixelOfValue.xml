<refentry xml:id="RT_ST_PixelOfValue" xmlns="http://docbook.org/ns/docbook">
            <refnamediv>
                <refname>ST_PixelOfValue</refname>
                <refpurpose>
                    Get the columnx, rowy coordinates of the pixel whose value equals the search value.
                </refpurpose>
            </refnamediv>

            <refsynopsisdiv>
                <funcsynopsis>
                    <funcprototype>
