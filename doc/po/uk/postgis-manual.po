msgid "Encode the same WGS 84 LineString using precision 5 and 6."
msgstr ""

#. Tag: para
#, no-c-format
msgid ""
"Decode an OSRM <literal>route.geometry</literal> returned with "
"<literal>geometries=polyline6</literal>."
msgstr ""

#. Tag: para
#, no-c-format
msgid ""
"The Google Maps JavaScript Geometry library decodes precision-5 strings. "
"This browser example assumes that <varname>map</varname> is an initialized "
"Google map."
msgstr ""

