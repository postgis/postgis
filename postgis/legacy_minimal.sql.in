-- Bare minimum Legacy functions --
-- This file that contains what we have determined are
-- the most common functions used by older apps
-- You should be able to get by with just to support
-- older versions of mapserver, geoserver, qgis, gdal, openjump etc.
#include "sqldefines.h"

DO $postgis_legacy_minimal$
DECLARE
	postgis_schema text := pg_catalog.current_schema();
BEGIN
	PERFORM pg_catalog.set_config(
		'postgis.legacy_minimal_original_search_path',
		pg_catalog.current_setting('search_path'),
		false
	);
	PERFORM pg_catalog.set_config(
		'search_path',
		pg_catalog.quote_ident(postgis_schema) || ', pg_catalog',
		false
	);
END;
$postgis_legacy_minimal$;

-- These wrappers replace the legacy SQL surface, but pg_upgrade may still need
-- the historical C entry points recorded in older catalogs. If any of the
-- LWGEOM_* exports below are ever retired, move them into postgis_legacy.c
-- before changing these wrappers.

-- Deprecation in 1.2.3
CREATE OR REPLACE FUNCTION AsBinary(geometry)
	RETURNS bytea
	AS $$
		SELECT @extschema@._postgis_deprecate('AsBinary', 'ST_AsBinary', '1.2.3');
		SELECT @extschema@.ST_AsBinary($1);
	$$
	LANGUAGE 'sql' IMMUTABLE STRICT SET search_path FROM CURRENT;

-- Deprecation in 1.2.3
CREATE OR REPLACE FUNCTION AsBinary(geometry,text)
	RETURNS bytea
	AS $$
		SELECT @extschema@._postgis_deprecate('AsBinary', 'ST_AsBinary', '1.2.3');
		SELECT @extschema@.ST_AsBinary($1, $2);
	$$
	LANGUAGE 'sql' IMMUTABLE STRICT SET search_path FROM CURRENT;

-- Deprecation in 1.2.3
CREATE OR REPLACE FUNCTION AsText(geometry)
	RETURNS TEXT
	AS $$
		SELECT @extschema@._postgis_deprecate('AsText', 'ST_AsText', '1.2.3');
		SELECT @extschema@.ST_AsText($1);
	$$
	LANGUAGE 'sql' IMMUTABLE STRICT SET search_path FROM CURRENT;

-- Deprecation in 1.2.3
CREATE OR REPLACE FUNCTION Estimated_Extent(text,text,text) RETURNS box2d AS
	'MODULE_PATHNAME', 'geometry_estimated_extent'
	LANGUAGE 'c' IMMUTABLE STRICT SECURITY DEFINER;

-- Deprecation in 1.2.3
CREATE OR REPLACE FUNCTION Estimated_Extent(text,text) RETURNS box2d AS
	'MODULE_PATHNAME', 'geometry_estimated_extent'
	LANGUAGE 'c' IMMUTABLE STRICT SECURITY DEFINER;

-- Deprecation in 1.2.3
CREATE OR REPLACE FUNCTION GeomFromText(text, int4)
	RETURNS geometry AS $$
		SELECT @extschema@._postgis_deprecate('GeomFromText', 'ST_GeomFromText', '1.2.3');
		SELECT @extschema@.ST_GeomFromText($1, $2);
	$$
	LANGUAGE 'sql' IMMUTABLE STRICT SET search_path FROM CURRENT;

-- Deprecation in 1.2.3
CREATE OR REPLACE FUNCTION GeomFromText(text)
	RETURNS geometry AS $$
		SELECT @extschema@._postgis_deprecate('GeomFromText', 'ST_GeomFromText', '1.2.3');
		SELECT @extschema@.ST_GeomFromText($1);
	$$
	LANGUAGE 'sql' IMMUTABLE STRICT SET search_path FROM CURRENT;

-- Deprecation in 1.2.3
CREATE OR REPLACE FUNCTION ndims(geometry)
	RETURNS smallint
	AS $$
		SELECT @extschema@._postgis_deprecate('ndims', 'ST_NDims', '1.2.3');
		SELECT @extschema@.ST_NDims($1);
	$$
	LANGUAGE 'sql' IMMUTABLE STRICT SET search_path FROM CURRENT;

-- Deprecation in 1.2.3
CREATE OR REPLACE FUNCTION SetSRID(geometry,int4)
	RETURNS geometry
	AS $$
		SELECT @extschema@._postgis_deprecate('SetSRID', 'ST_SetSRID', '1.2.3');
		SELECT @extschema@.ST_SetSRID($1, $2);
	$$
	LANGUAGE 'sql' IMMUTABLE STRICT SET search_path FROM CURRENT;

-- Deprecation in 1.2.3
CREATE OR REPLACE FUNCTION SRID(geometry)
	RETURNS int4
	AS $$
		SELECT @extschema@._postgis_deprecate('SRID', 'ST_SRID', '1.2.3');
		SELECT @extschema@.ST_SRID($1);
	$$
	LANGUAGE 'sql' IMMUTABLE STRICT SET search_path FROM CURRENT;

-- Deprecation in 1.5.0
-- hack to allow unknown to cast to geometry
-- so does not yield function is not unique
CREATE OR REPLACE FUNCTION ST_AsBinary(text)
	RETURNS bytea
	AS
	$$
		SELECT @extschema@._postgis_deprecate('ST_AsBinary(text)', 'ST_AsBinary(geometry)', '1.5.0');
		SELECT @extschema@.ST_AsBinary($1::@extschema@.geometry);
	$$
	LANGUAGE 'sql' IMMUTABLE STRICT SET search_path FROM CURRENT;

-- Deprecation in 1.5.0
-- hack to allow unknown to cast to geometry
-- so does not yield function is not unique
CREATE OR REPLACE FUNCTION ST_AsText(bytea)
	RETURNS text
	AS
	$$
		SELECT @extschema@._postgis_deprecate('ST_AsText(bytea)', 'ST_AsText(geometry)', '1.5.0');
		SELECT @extschema@.ST_AsText($1::@extschema@.geometry);
	$$
	LANGUAGE 'sql' IMMUTABLE STRICT SET search_path FROM CURRENT;

DO $postgis_legacy_minimal$
DECLARE
	original_search_path text := pg_catalog.current_setting(
		'postgis.legacy_minimal_original_search_path',
		true
	);
BEGIN
	IF original_search_path IS NOT NULL THEN
		PERFORM pg_catalog.set_config('search_path', original_search_path, false);
		PERFORM pg_catalog.set_config('postgis.legacy_minimal_original_search_path', '', false);
	END IF;
END;
$postgis_legacy_minimal$;
