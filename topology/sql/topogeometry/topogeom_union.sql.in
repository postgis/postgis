-- {
--  Aggregate union transition function for TopoGeometry values
--
-- }{
-- Availability: 3.7.0
CREATE OR REPLACE FUNCTION topology._ST_Union(state topology.TopoGeometry, src topology.TopoGeometry)
  RETURNS topology.TopoGeometry
AS
$$
DECLARE
  topo_name TEXT;
BEGIN
  IF src IS NULL THEN
    RETURN state;
  END IF;

  SELECT name
  FROM topology.topology
  WHERE id = topology_id(src)
  INTO STRICT topo_name;

  IF state IS NULL THEN
    state := topology.CreateTopoGeom(
      topo_name,
      type(src),
      layer_id(src)
    );
  END IF;

  state := topology.TopoGeom_addTopoGeom(state, src);

  RETURN state;
END
$$
LANGUAGE 'plpgsql' VOLATILE;
-- }

-- Availability: 3.7.0
CREATE AGGREGATE topology.ST_Union(topology.TopoGeometry) (
  SFUNC = topology._ST_Union,
  STYPE = topology.TopoGeometry,
  PARALLEL = unsafe
);
